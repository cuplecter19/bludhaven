# ──────────────────────────────────────────────
# Bludhaven environment variables – copy to .env
# ──────────────────────────────────────────────

# Django core
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database (leave DB_ENGINE unset or set to sqlite3 for local dev)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=toybox_db
DB_USER=admin
DB_PASSWORD=strongpassword
DB_HOST=db
DB_PORT=5432
